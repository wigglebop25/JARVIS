{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "jarvis",
  "version": "0.1.0",
  "identifier": "com.jm.jarvis",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "jarvis",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:1420; img-src 'self' asset: http://asset.localhost; media-src 'self' asset: http://asset.localhost http://localhost:1420; script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline';",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
